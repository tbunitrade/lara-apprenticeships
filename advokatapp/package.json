{
    "name": "osonich",
    "private": true,
    "description": "Проект требует Node.js версии 20.15.0 или выше.",
    "engines": {
        "node": ">=20.15.0"
    },
    "browserslist": [
        "last 4 versions",
        "defaults",
        "> 0.2%",
        "not dead"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "watchfull": "nodemon -e scss -x \"npm run compile:css && npm run compile:cssfonts\"",
        "build:css": "npm run compile:css",
        "watch:css": "nodemon -e scss -x \"npm run build:css\"",
        "compile:css": "sass --style=compressed src/scss/app.scss public/css/main.min.css && postcss public/css/main.min.css -o public/css/main.min.css",
        "compile:cssfonts": "sass --style=compressed src/scss/fonts.scss public/css/fonts.css"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.13",
        "axios": "^1.1.2",
        "cssmin": "^0.4.3",
        "laravel-vite-plugin": "^0.6.0",
        "lodash": "^4.17.19",
        "nodemon": "^2.0.20",
        "postcss": "^8.4.6",
        "postcss-cli": "^10.1.0",
        "sass": "^1.60.0",
        "tailwindcss": "^3.1.0",
        "vite": "^3.0.0"
    },
    "dependencies": {
        "@glidejs/glide": "^3.7.1",
        "inputmask": "^5.0.7",
        "keen-slider": "^6.7.0",
        "postcss-import": "^16.1.1"
    }
}
